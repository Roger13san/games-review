# ─── Banco de dados ───────────────────────────────────────────────────────────

# URI de conexão com o MongoDB
# Local:      mongodb://localhost:27017
# Atlas:      mongodb+srv://<user>:<password>@cluster.mongodb.net
MONGODB_URI=mongodb://localhost:27017

# Nome do banco de dados
DB_NAME=games_review

# ─── Servidor ─────────────────────────────────────────────────────────────────

# Porta em que o backend vai rodar
PORT=8081

# URL base do backend — usada como return_to no fluxo OpenID da Steam
# Em produção: https://api.seudominio.com
APP_BASE_URL=http://localhost:8081

# URL do frontend — para onde redirecionar após o login com a Steam
# Em produção: https://seudominio.com
FRONTEND_URL=http://localhost:5173

# ─── Autenticação ─────────────────────────────────────────────────────────────

# Chave secreta para assinar os JWTs
# Gere uma chave segura: openssl rand -base64 32
JWT_SECRET=

# ─── Steam ────────────────────────────────────────────────────────────────────

# API key da Steam Web API
# Obtenha gratuitamente em: https://steamcommunity.com/dev/apikey
STEAM_API_KEY=
